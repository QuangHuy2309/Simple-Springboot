<!--
  IntelliJ shared run configuration — committed to version control.

  Profile: stage
    • PostgreSQL (credentials from environment variables — never hard-code them here)
    • Hibernate SessionFactory used directly for Order queries (demonstrates
      native Hibernate API vs Spring Data JPA abstraction)
    • JPA validate mode — Flyway owns schema; Hibernate only validates column mapping
    • HikariCP connection pool (min 5, max 20 connections)
    • INFO/WARN logging only — no SQL echo

  Required environment variables (set in Run/Debug → Environment variables):
    DB_URL      = jdbc:postgresql://localhost:5432/orderdb
    DB_USERNAME = postgres
    DB_PASSWORD = <your password>

  How to use:
    1. Open Run/Debug Configurations in IntelliJ
    2. Select "Run — Stage"
    3. Click "Edit" → "Environment variables" and fill in DB_URL / DB_USERNAME / DB_PASSWORD
    4. Run — PostgreSQL must be running and the database must exist
-->
<component name="ProjectRunConfigurationManager">
  <configuration default="false"
                 name="Run — Stage"
                 type="SpringBootApplicationConfigurationType"
                 factoryName="Spring Boot">

    <option name="SPRING_BOOT_MAIN_CLASS" value="com.example.demo.DemoApplication"/>

    <!-- Activates application-stage.yml on top of application.yml -->
    <option name="ACTIVE_PROFILES" value="stage"/>

    <module name="demo"/>

    <!--
      Larger heap for stage: more data, real DB driver buffers, HikariCP pool overhead.
      -XX:+UseG1GC: G1 garbage collector — better pause-time predictability than default
      -Dhibernate.generate_statistics=true: prints Hibernate stats on shutdown (useful for tuning)
    -->
    <option name="VM_PARAMETERS"
            value="-Xms512m -Xmx1024m -XX:+UseG1GC -Dhibernate.generate_statistics=true"/>

    <!--
      Environment variables are NOT stored here to avoid committing secrets.
      Each developer or CI pipeline sets them externally.
      The application-stage.yml reads them via ${DB_URL}, ${DB_USERNAME}, ${DB_PASSWORD}.
    -->
    <envs>
      <env name="DB_URL"      value="jdbc:postgresql://localhost:5432/orderdb"/>
      <env name="DB_USERNAME" value="postgres"/>
      <env name="DB_PASSWORD" value="changeme"/>
    </envs>

    <method v="2">
      <option name="Make" enabled="true"/>
    </method>
  </configuration>
</component>
